Windows Registry Editor Version 5.00

[HKEY_CLASSES_ROOT\Directory\Background\shell\FixWSA]
@="Fix Android Icons"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\Directory\Background\shell\FixWSA\command]
@="powershell.exe -Command \"Start-Process powershell.exe -ArgumentList '-ExecutionPolicy Bypass -File \\\"Z:\\Projects (Z:)\\Batch\\Fix_Android WSA Icons.ps1\\\"' -Verb RunAs\""